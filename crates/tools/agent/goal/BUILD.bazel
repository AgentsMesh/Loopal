load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

rust_library(
    name = "loopal-tool-goal",
    srcs = glob(["src/**/*.rs"]),
    edition = "2024",
    visibility = ["//visibility:public"],
    deps = [
        "//crates/loopal-error:loopal-error",
        "//crates/loopal-protocol:loopal-protocol",
        "//crates/loopal-tool-api:loopal-tool-api",
        "@crates//:serde",
        "@crates//:serde_json",
    ],
    proc_macro_deps = ["@crates//:async-trait"],
)

rust_test(
    name = "loopal-tool-goal-test",
    srcs = glob(["tests/**/*.rs"]),
    crate_root = "tests/suite.rs",
    edition = "2024",
    deps = [
        ":loopal-tool-goal",
        "//crates/loopal-error",
        "//crates/loopal-protocol",
        "//crates/loopal-tool-api",
        "@crates//:chrono",
        "@crates//:serde_json",
        "@crates//:tokio",
    ],
    proc_macro_deps = ["@crates//:async-trait"],
)
