load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

rust_library(
    name = "loopal-view-state",
    srcs = glob(["src/**/*.rs"]),
    edition = "2024",
    visibility = ["//visibility:public"],
    deps = [
        "//crates/loopal-protocol",
        "//crates/loopal-tool-api",
        "@crates//:indexmap",
        "@crates//:serde",
        "@crates//:serde_json",
    ],
)

rust_test(
    name = "loopal-view-state_test",
    srcs = glob(["tests/**/*.rs"]),
    crate_root = "tests/suite.rs",
    edition = "2024",
    deps = [
        ":loopal-view-state",
        "//crates/loopal-protocol",
        "@crates//:serde_json",
    ],
)
