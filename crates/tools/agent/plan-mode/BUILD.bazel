load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

rust_library(
    name = "loopal-tool-plan-mode",
    srcs = glob(["src/**/*.rs"]),
    edition = "2024",
    visibility = ["//visibility:public"],
    deps = [
        "//crates/loopal-error:loopal-error",
        "//crates/loopal-tool-api:loopal-tool-api",
        "@crates//:serde_json",
    ],
    proc_macro_deps = ["@crates//:async-trait"],
)

rust_test(
    name = "loopal-tool-plan-mode-test",
    srcs = glob(["tests/**/*.rs"]),
    crate_root = "tests/plan_mode_test.rs",
    edition = "2024",
    deps = [
        ":loopal-tool-plan-mode",
        "//crates/loopal-tool-api",
    ],
)
